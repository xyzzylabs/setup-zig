{
  "name": "setup-zig",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action that installs the Zig compiler and caches the global Zig cache directory.",
  "type": "module",
  "main": "src/main.ts",
  "homepage": "https://github.com/xyzzylabs/setup-zig#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xyzzylabs/setup-zig.git"
  },
  "bugs": {
    "url": "https://github.com/xyzzylabs/setup-zig/issues"
  },
  "author": "Sergey Rubanov",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsgo --project tsconfig.json",
    "test": "node --test 'test/*.test.ts'",
    "build": "ncc build src/main.ts -o dist/main --license licenses.txt && ncc build src/post.ts -o dist/post --license licenses.txt",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "actions",
    "zig",
    "ziglang",
    "setup",
    "github-actions",
    "minisign"
  ],
  "dependencies": {
    "@actions/cache": "^6.0.1",
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^6.0.3"
  }
}
